---
interface Props {
  class?: string;
  size?: 'nav' | 'hero';
}

const { class: className = '', size = 'hero' } = Astro.props;

const sizeClasses = size === 'nav'
  ? 'text-2xl'
  : 'text-6xl sm:text-7xl md:text-8xl';
---

<span
  class:list={[
    "font-['VT323'] text-accent inline-block tracking-tighter",
    sizeClasses,
    className,
  ]}
  aria-label="Feynman"
>feynman</span>
